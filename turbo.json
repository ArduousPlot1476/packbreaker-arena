{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "!dist/**/*.map"]
    },
    "@packbreaker/client#build": { "cache": false },
    "lint": {
      "dependsOn": ["//#check-schemas-sync"]
    },
    "//#check-schemas-sync": {
      "inputs": [
        "content-schemas.ts",
        "packages/content/src/schemas.ts",
        "tooling/scripts/check-schemas-sync.cjs"
      ],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": [],
      "env": ["TEST_DATABASE_URL", "CI"]
    },
    "test:determinism": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "test/determinism/**",
        "test/fixtures/runs/**"
      ],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
