    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@packbreaker/eslint-config": "workspace:*",
    "@packbreaker/tsconfig": "workspace:*",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^8.57.0",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  }
}
