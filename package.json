{
  "name": "packbreaker-arena",
  "version": "0.0.1",
  "private": true,
  "description": "Browser-based asynchronous inventory auto-battler. Monorepo root.",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
