{
  "name": "@packbreaker/sim",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:determinism": "vitest run test/determinism/harness.test.ts",
    "generate-fixtures": "vitest run test/determinism/regenerate.test.ts"
  },
  "dependencies": {
    "@packbreaker/content": "workspace:*"
  },
  "devDependencies": {
    "@packbreaker/eslint-config": "workspace:*",
    "@packbreaker/tsconfig": "workspace:*",
    "@vitest/coverage-v8": "^2.1.8",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
