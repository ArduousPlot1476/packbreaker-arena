# apps/server/.env.example — copy to apps/server/.env and fill in real values.
# Only .env is loaded at boot (via `tsx watch --env-file-if-exists=.env`); this template is committed.
# That flag needs Node >=20.19.0 (20.x LTS) or >=22.9.0 (see apps/server/package.json engines).
POSTHOG_PROJECT_KEY=
POSTHOG_HOST=https://us.i.posthog.com
# PORT defaults to 4000 and LOG_LEVEL defaults to info when left blank (see env.ts).
PORT=
LOG_LEVEL=
