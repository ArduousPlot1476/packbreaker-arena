  },
  "devDependencies": {
    "@packbreaker/eslint-config": "workspace:*",
    "@packbreaker/tsconfig": "workspace:*",
    "@types/node": "^20.17.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
